#!/bin/bash

entries="‚èæ Suspend\n‚≠Æ Reboot\n‚èª Shutdown\n‚èª Logout"

chosen=$(echo -e "$entries" | wofi --dmenu --width=250 --height=200 --prompt="Power Menu")

case $chosen in
    "‚èæ Suspend")
        systemctl suspend
        ;;
    "‚≠Æ Reboot")
        systemctl reboot
        ;;
    "‚èª Shutdown")
        systemctl poweroff
        ;;
    "‚èª Logout")
        hyprctl dispatch exit
        ;;
esac